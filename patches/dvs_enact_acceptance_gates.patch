+def test_eventvot_acceptance_can_gate_on_refiner_diagnostics():
+    module = _load_module()
+    config = module.EventVOTAcceptanceConfig(
+        min_polarity_consistency_fraction=0.70,
+        min_mean_event_polarity_weight=0.80,
+        max_quadratic_form=10.0,
+    )
+    candidate = np.array([10.0, 10.0, 20.0, 20.0])
+
+    accepted = module.evaluate_refinement_acceptance(
+        candidate,
+        _FakeResult(
+            [10.0, 10.0, 20.0, 20.0],
+            polarity_consistency_fraction=0.75,
+            mean_event_polarity_weight=0.90,
+            quadratic_form=9.0,
+        ),
+        config,
+    )
+    low_consistency = module.evaluate_refinement_acceptance(
+        candidate,
+        _FakeResult([10.0, 10.0, 20.0, 20.0], polarity_consistency_fraction=0.65),
+        config,
+    )
+    low_weight = module.evaluate_refinement_acceptance(
+        candidate,
+        _FakeResult([10.0, 10.0, 20.0, 20.0], mean_event_polarity_weight=0.75),
+        config,
+    )
+    high_quadratic = module.evaluate_refinement_acceptance(
+        candidate,
+        _FakeResult([10.0, 10.0, 20.0, 20.0], quadratic_form=11.0),
+        config,
+    )
+
+    assert accepted.accepted
+    assert not low_consistency.accepted
+    assert low_consistency.rejection_reasons == ("polarity_consistency_fraction",)
+    assert not low_weight.accepted
+    assert low_weight.rejection_reasons == ("mean_event_polarity_weight",)
+    assert not high_quadratic.accepted
+    assert high_quadratic.rejection_reasons == ("quadratic_form",)
+
